# Copy to `.env` for local `cargo run` / tests (`.env` is gitignored).
# Docker Compose sets these on the `app` service — you do not need `.env` for `docker compose up`.

DATABASE_URL=postgres://dodo:dodo@localhost:5433/dodo
LISTEN_ADDR=0.0.0.0:8080
MOCK_PSP_BASE_URL=http://127.0.0.1:8080
PAY_SYNC_WAIT_SECS=8
PSP_HTTP_TIMEOUT_SECS=35
RUST_LOG=dodo_invoice_service=info,tower_http=info
# LOG_FORMAT=json for one-line JSON logs (production / Docker default in compose)
